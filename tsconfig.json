{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2020", "DOM"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "backup"]
}
